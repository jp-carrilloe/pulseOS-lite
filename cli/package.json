{
  "name": "pulseos-lite-cli",
  "version": "1.0.0",
  "type": "module",
  "description": "PulseOS-Lite repo daemon — chat with your repo via Claude, OpenAI, or Gemini",
  "scripts": {
    "start": "node --import tsx/esm index.ts",
    "chat": "node --import tsx/esm index.ts chat",
    "chat:claude": "node --import tsx/esm index.ts chat --model claude",
    "chat:openai": "node --import tsx/esm index.ts chat --model openai",
    "chat:gemini": "node --import tsx/esm index.ts chat --model gemini",
    "index": "node --import tsx/esm index-kb.ts",
    "ui:build": "vite build --config frontend/vite.config.ts",
    "ui:dev": "vite --config frontend/vite.config.ts",
    "ui": "npm run ui:build && node --import tsx/esm index.ts ui",
    "graph:build": "npm run ui:build",
    "graph:dev": "npm run ui:dev",
    "graph": "npm run ui",
    "mcp": "node --import tsx/esm mcp-server.ts",
    "status": "node --import tsx/esm index.ts status",
    "daemon:start": "node --import tsx/esm index.ts daemon start",
    "daemon:stop": "node --import tsx/esm index.ts daemon stop",
    "daemon:status": "node --import tsx/esm index.ts daemon status",
    "bootstrap": "node --import tsx/esm bootstrap.ts",
    "test": "node --import tsx/esm --test *.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.0",
    "@hono/node-server": "^1.13.7",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cytoscape": "^3.30.4",
    "cytoscape-fcose": "^2.2.0",
    "hono": "^4.7.9",
    "node-pty": "^1.1.0",
    "openai": "^4.82.0",
    "react": "^19.0.0",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
